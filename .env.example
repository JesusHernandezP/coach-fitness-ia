# Base de datos
DB_URL=jdbc:postgresql://localhost:5432/fitnesscoach
DB_USER=postgres
DB_PASSWORD=changeme

# JWT (minimo 32 caracteres aleatorios)
JWT_SECRET=replace-this-with-a-random-secret-min-32-chars

# Groq LLM (https://console.groq.com)
GROQ_API_KEY=gsk_...

# Backend
SPRING_PROFILES_ACTIVE=dev
APP_CORS_ALLOWED_ORIGINS=http://localhost:4200
APP_DOCS_ENABLED=true

# PostgreSQL Docker (usado por docker-compose.yml)
POSTGRES_DB=fitnesscoach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
